	handle @app2 {
		reverse_proxy app2:3000
	}

	@app3 path /app3 /app3/*
	handle @app3 {
		reverse_proxy app3:3000
	}

	@app4 path /app4 /app4/*
	handle @app4 {
		reverse_proxy app4:3000
	}

	@app5 path /app5 /app5/*
